# Production Environment Variables
# Copy this file to .env.production and fill in the values

# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_NAME=swifttiger
DB_USER=postgres
DB_PASSWORD=your_secure_database_password_here

# JWT Secret - MUST be a secure random string (minimum 32 characters)
JWT_SECRET=your_secure_jwt_secret_minimum_32_characters_long

# Server Configuration
PORT=5000
NODE_ENV=production

# Frontend URL for CORS
FRONTEND_URL=https://yourdomain.com

# Google Maps API Key (optional but recommended for route features)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Email Configuration (for password reset functionality)
EMAIL_HOST=smtp.your-email-provider.com
EMAIL_PORT=587
EMAIL_USER=your_email_username
EMAIL_PASSWORD=your_email_password
EMAIL_FROM=noreply@yourdomain.com

# Logging Configuration
LOG_LEVEL=info

# Optional: Redis Configuration (for session management)
REDIS_URL=redis://redis:6379

# Optional: SSL Configuration
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem